# ===== REQUIRED KEYS =====
# Get from https://console.groq.com/keys (free)
GROQ_API_KEY=your_groq_key_here

# Get from https://the-odds-api.com (free, 500 req/month)
ODDS_API_KEY=your_odds_api_key_here

# Auto-populated by Vercel Postgres integration. For local dev, use a Vercel-linked DB.
POSTGRES_URL=

# Random secret string to protect the cron endpoints. Generate any long random string.
CRON_SECRET=generate_a_random_string_here

# ===== OPTIONAL =====
# Defaults to 100. Your unit size in dollars for the tracking page display.
UNIT_SIZE_USD=100
